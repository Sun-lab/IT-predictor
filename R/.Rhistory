rm(CBST.genes)
CBST.largeExpression.genes = CBST.genes[CBST.genes %in% large.express.genes.all] # 221 out of 538
CBST.largeExpression.genes = CBST.SFgenes[CBST.SFgenes %in% large.express.genes.all] # 221 out of 538
CBST_SFLEgenes_LM22 = CBST_LM22[as.character(CBST_LM22$Gene.symbol)%in%CBST.largeExpression.genes,]
rm(CSBT_SFgenes_LM22)
