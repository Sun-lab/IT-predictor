colnames(cormat)= colnames(compare_expression)
rownames(cormat) = colnames(CBST_SFLEgenes_LM22)
colnames(CBST_SFLEgenes_LM22)[-1]
cormat = matrix(0,nrow = 22, ncol = 11)
colnames(cormat)= colnames(compare_expression)
rownames(cormat) = colnames(CBST_SFLEgenes_LM22)[-1]
for (i in 1:22) {
for (j in 1:11) {
cormat[i,j] = cor(as.numeric(compare_expression[,j]), as.numeric(CBST_SFLEgenes_LM22[,i]),method = "spearman")
}
}
cormat
ggcorrplot(t(cormat))
ggcorrplot(corr = cor(compare_expression),method = "spearman")
cor(compare_expression)
cormat = cor(compare_expression)
ggcorrplot(cormat, method = "spearman")
ggcorrplot(cor(compare_expression, method = "spearman"))
ggcorrplot(cor(compare_expression, method = "spearman"),type = "upper")
