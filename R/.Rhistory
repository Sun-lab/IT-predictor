head(CBST.largeExpression.genes.all)
head(CBST_SFLEgenes_LM22)
# TPM data of signature genes for only TNK cells
Allcells_CBSTLEgenes_tpm = sf_tpm[rownames(sf_tpm) %in% CBST.largeExpression.genes.all,]
Allcells_CBSTLEgenes_tpm[1:10,1:10]
