large.expressed.tpm = CDNKcells_tpm[match(large.express.genes,rownames(CDNKcells_tpm)),]
large.expressed.tpm[1:10,1:10]
rownames(CDNKcells_tpm)
row.names(CDNKcells_tpm) = gene.names
rownames(CDNKcells_tpm)
large.expressed.tpm = CDNKcells_tpm[match(large.express.genes,rownames(CDNKcells_tpm)),]
large.expressed.tpm[1:10,1:10]
# plot the variance of the expression levels for each gene against its mean expression level
genes.mean = apply(large.expressed.tpm, 1, mean)
genes.variance = apply(large.expressed.tpm, 1, var)
df_mv = data.frame(gene=large.express.genes, mean=genes.mean, var=genes.variance)
df_mv
rm(large.express.genes)
rm(large.expressed.tpm)
rm(genes.mean)
rm(genes.variance)
ggplot(data = df_mv) +
geom_point(aes(x=mean,y=var),size = 0.1)
# divide the genes into 20 equal-size bins based on their mean expression levels
df_mv$grouping = cut_number(df_mv$mean, n=20)
table(df_mv$grouping)
# in each bin, select the first 50 genes with the highest variance
hv.genes.list = by(df_mv, df_mv$grouping, FUN = function(df) return(df$gene[order(df$var,decreasing = TRUE)][1:50]))
hv.genes = as.character(unlist(hv.genes.list))
rm(hv.genes.list)
hvg_tpm = CDNKcells_tpm[match(hv.genes,rownames(CDNKcells_tpm)),]
hvg_tpm = t(hvg_tpm)
colnames(hvg_tpm) = hv.genes
rm(df_mv)
rm(hvg_tpm)
hvg_CDNKcells_tpm = CDNKcells_tpm[match(hv.genes,rownames(CDNKcells_tpm)),]
hvg_CDNKcells_tpm = t(hvg_tpm)
hvg_CDNKcells_tpm = t(hvg_CDNKcells_tpm)
colnames(hvg_CDNKcells_tpm) = hv.genes
hvg_CDNKcells_tpm[1:10,1:10]
pca.hvg = princomp(hvg_CDNKcells_tpm, cor = TRUE)
rm(hvg_CDNKcells_tpm)
pca.scores = pca.hvg$scores
rm(pca.hvg)
top50pcs_CDNKcells = pca.scores[,1:50]
rm(pca.scores)
#head(top50pcs_CDNKcells)
set.seed(9999)
tsne = Rtsne(top50pcs_CDNKcells, pca=FALSE)
df_tsne = as.data.frame(tsne$Y)
names(df_tsne) = paste0("topPC_TSNE",seq(ncol(tsne$Y)))
rm(tsne)
df_top50PCs_CDNKcells = cbind(top50pcs_CDNKcells, df_tsne)
rm(df_tsne)
#head(df_top50PCs_CDNKcells)
set.seed(9999)
all_num_clust = c(3:6)
for (num_clust in all_num_clust) {
cat(paste0("KM with ",num_clust," clusters.\n"))
kmeans_out = kmeans(top50pcs_CDNKcells, centers = num_clust, iter.max = 1e3, nstart = 50, algorithm = "MacQueen")
print(kmeans_out[c("betweenss","tot.withinss")])
km_label = paste0("KM_",num_clust)
df_top50PCs_CDNKcells[[km_label]] = as.factor(kmeans_out$cluster)
pt = ggplot(data=df_top50PCs_CDNKcells)+geom_point(aes(x=topPC_TSNE1,y=topPC_TSNE2,color=eval(as.name(paste(km_label)))),size = 0.1)+scale_colour_discrete(name=paste(km_label))+guides(color = guide_legend(override.aes = list(size = 2)))
print(pt)
rm(kmeans_out)
rm(pt)
}
